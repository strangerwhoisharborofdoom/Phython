# Multiplication table
num = int(input("Enter a number: "))

print("\nMultiplication Table:")
for i in range(1, 11):
    print(num, "x", i, "=", num * i)

# Sum of numbers
n = int(input("\nEnter n to find sum from 1 to n: "))

total = 0
for i in range(1, n+1):
    total += i

print("Sum =", total)


